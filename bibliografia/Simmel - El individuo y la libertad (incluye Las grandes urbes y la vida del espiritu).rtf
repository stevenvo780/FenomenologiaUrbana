\par }\pard\plain \qj \li0\ri0\sb100\sa100\sbauto1\saauto1\widctlpar\faauto\rin0\lin0\itap0 \fs24\lang1033\langfe3082\cgrid\langnp1033\langfenp3082 {\b\f27\lang1034\langfe3082\langnp1034 GEORG SIMMEL
